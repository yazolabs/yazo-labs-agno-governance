# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Production — JWT verification for AgentOS RBAC.
# AgentOS enables RBAC whenever RUNTIME_ENV=prd (the default outside dev).
# Without this key, prod refuses to serve traffic. Generate the keypair at
# os.agno.com (your OS → Settings → Token Based Authorization) after your
# first deploy fails. Paste the full PEM block, no surrounding quotes.
# Set `authorization=False` in app/main.py to opt out (not recommended).
# ---------------------------------------------------------------------------
# JWT_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkq...
# -----END PUBLIC KEY-----

# ---------------------------------------------------------------------------
# AgentOS scheduler base URL. Defaults to http://127.0.0.1:8000 for local development.
# When AgentOS is deployed to a different domain, set this to the public URL.
# ---------------------------------------------------------------------------
# AGENTOS_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Web search — WebSearch Agent uses Parallel's MCP server.
#   PARALLEL_API_KEY set  →  authenticated /mcp endpoint (higher rate ceiling)
#   unset                 →  keyless /mcp endpoint (good for dev)
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Slack — set both to enable the Slack interface.
#   SLACK_BOT_TOKEN       Bot User OAuth Token (xoxb-***)
#   SLACK_SIGNING_SECRET  Signing Secret (Basic Information → App Credentials)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg

# ---------------------------------------------------------------------------
# Optional — alternate model providers
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
